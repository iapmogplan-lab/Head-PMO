import streamlit as st
import database
import agent
import os
import pandas as pd
import plotly.express as px
from datetime import datetime

# Initialize the database
database.init_db()

# Set page config
st.set_page_config(layout="wide", page_title="Agente de Gerenciamento de Projetos")

# --- Sidebar Navigation ---
with st.sidebar:
    st.title("Project Agent")
    page = st.radio(
        "Navegação",
        ["Dashboard", "Gerenciar Projetos e Tarefas", "Chat com o Agente"]
    )
    st.markdown("""
    --- 
    **Como usar o Chat com o Agente:**
    - "Crie um projeto chamado 'Marketing' com descrição 'Campanha de lançamento'."
    - "Crie uma tarefa 'Criar logo' para o projeto 'Marketing' com prazo para 2024-12-31 e atribuída a 'Ana'."
    - "Liste as tarefas do projeto 'Marketing'."
    - "Atualize o status da tarefa 1 para 'Concluído'."
    - "Quais são os projetos atuais?"
    """)

# --- Dashboard Page ---
if page == "Dashboard":
    st.header("Dashboard de Projetos")

    projects = database.get_projects()
    tasks = database.get_tasks()

    if not projects:
        st.info("Nenhum projeto encontrado. Crie um novo projeto na seção 'Gerenciar Projetos e Tarefas'.")
    else:
        # Project Overview
        st.subheader("Visão Geral dos Projetos")
        df_projects = pd.DataFrame(projects)
        st.dataframe(df_projects, use_container_width=True)

        # Task Status Distribution
        st.subheader("Distribuição de Status das Tarefas")
        if tasks:
            df_tasks = pd.DataFrame(tasks)
            status_counts = df_tasks["status"].value_counts().reset_index()
            status_counts.columns = ["Status", "Contagem"]
            fig = px.pie(status_counts, values="Contagem", names="Status", title="Status das Tarefas")
            st.plotly_chart(fig, use_container_width=True)

            # Tasks by Project
            st.subheader("Tarefas por Projeto")
            df_tasks_with_project_name = df_tasks.merge(df_projects[['id', 'name']], left_on='project_id', right_on='id', suffixes=('_task', '_project'))
            tasks_by_project = df_tasks_with_project_name.groupby('name_project')['id_task'].count().reset_index()
            tasks_by_project.columns = ["Projeto", "Número de Tarefas"]
            fig_bar = px.bar(tasks_by_project, x="Projeto", y="Número de Tarefas", title="Número de Tarefas por Projeto")
            st.plotly_chart(fig_bar, use_container_width=True)

        else:
            st.info("Nenhuma tarefa encontrada.")

# --- Manage Projects and Tasks Page ---
elif page == "Gerenciar Projetos e Tarefas":
    st.header("Gerenciar Projetos e Tarefas")

    # --- Project Management ---
    st.subheader("Gerenciar Projetos")
    with st.form("project_form", clear_on_submit=True):
        project_name = st.text_input("Nome do Projeto")
        project_description = st.text_area("Descrição do Projeto")
        submitted_project = st.form_submit_button("Adicionar Projeto")
        if submitted_project and project_name:
            if database.add_project(project_name, project_description):
                st.success(f"Projeto '{project_name}' adicionado com sucesso!")
            else:
                st.error(f"Projeto '{project_name}' já existe ou houve um erro.")

    projects = database.get_projects()
    if projects:
        df_projects = pd.DataFrame(projects)
        st.dataframe(df_projects, use_container_width=True)

        project_to_delete = st.selectbox("Selecionar Projeto para Deletar", [p['name'] for p in projects], key="delete_project_select")
        if st.button("Deletar Projeto Selecionado"):
            project_id_to_delete = next((p['id'] for p in projects if p['name'] == project_to_delete), None)
            if project_id_to_delete:
                database.delete_project(project_id_to_delete)
                st.success(f"Projeto '{project_to_delete}' e suas tarefas deletados.")
                st.rerun()

    # --- Task Management ---
    st.subheader("Gerenciar Tarefas")
    projects_for_tasks = database.get_projects()
    if not projects_for_tasks:
        st.warning("Crie um projeto antes de adicionar tarefas.")
    else:
        project_names = [p['name'] for p in projects_for_tasks]
        selected_project_name = st.selectbox("Selecionar Projeto", project_names, key="task_project_select")
        selected_project_id = next((p['id'] for p in projects_for_tasks if p['name'] == selected_project_name), None)

        with st.form("task_form", clear_on_submit=True):
            task_description = st.text_area("Descrição da Tarefa")
            task_status = st.selectbox("Status", ["A Fazer", "Em Andamento", "Concluído"], key="task_status_select")
            task_due_date = st.date_input("Data de Vencimento (Opcional)", value=None)
            task_assigned_to = st.text_input("Atribuído a (Opcional)")
            submitted_task = st.form_submit_button("Adicionar Tarefa")
            if submitted_task and task_description and selected_project_id:
                due_date_str = task_due_date.isoformat() if task_due_date else None
                database.add_task(selected_project_id, task_description, task_status, due_date_str, task_assigned_to)
                st.success(f"Tarefa '{task_description}' adicionada ao projeto '{selected_project_name}'.")
                st.rerun()

        st.markdown("### Tarefas do Projeto Selecionado")
        if selected_project_id:
            tasks_for_selected_project = database.get_tasks(selected_project_id)
            if tasks_for_selected_project:
                df_tasks_project = pd.DataFrame(tasks_for_selected_project)
                st.dataframe(df_tasks_project, use_container_width=True)

                # Update Task Status
                st.markdown("#### Atualizar Status da Tarefa")
                task_ids = [t['id'] for t in tasks_for_selected_project]
                if task_ids:
                    task_to_update_id = st.selectbox("Selecionar ID da Tarefa para Atualizar", task_ids, key="update_task_id_select")
                    new_status = st.selectbox("Novo Status", ["A Fazer", "Em Andamento", "Concluído"], key="new_status_select")
                    if st.button("Atualizar Status da Tarefa"):
                        database.update_task(task_to_update_id, status=new_status)
                        st.success(f"Status da tarefa {task_to_update_id} atualizado para '{new_status}'.")
                        st.rerun()

                # Delete Task
                st.markdown("#### Deletar Tarefa")
                task_to_delete_id = st.selectbox("Selecionar ID da Tarefa para Deletar", task_ids, key="delete_task_id_select")
                if st.button("Deletar Tarefa Selecionada"):
                    database.delete_task(task_to_delete_id)
                    st.success(f"Tarefa {task_to_delete_id} deletada.")
                    st.rerun()
            else:
                st.info("Nenhuma tarefa para este projeto.")

# --- Chat with Agent Page ---
elif page == "Chat com o Agente":
    st.header("Chat com o Agente de Gerenciamento de Projetos")

    if "messages" not in st.session_state:
        st.session_state.messages = []
        st.session_state.messages.append({"role": "assistant", "content": "Olá! Como posso ajudar a gerenciar seus projetos hoje?"})

    # Display chat messages from history on app rerun
    for message in st.session_state.messages:
        with st.chat_message(message["role"]):
            st.markdown(message["content"])

    # Accept user input
    if prompt := st.chat_input("Sua mensagem..."):
        with st.chat_message("user"):
            st.markdown(prompt)

        with st.chat_message("assistant"):
            with st.spinner("Pensando..."):
                response, st.session_state.messages = agent.run_conversation(prompt, st.session_state.messages)
                st.markdown(response)

    # Ensure OpenAI API Key is set
    if not os.getenv("GEMINI_API_KEY"):
        st.warning("Por favor, defina a variável de ambiente `GEMINI_API_KEY` para usar o chat com o agente.")
        st.stop()
